generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VideoTemplate {
  id          String   @id @default(cuid())
  name        String
  nameEn      String
  bg1         String
  bg2         String
  accentColor String
  patternType String   @default("none")
  icon        String   @default("")
  isPremium   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavedProject {
  id          String   @id @default(cuid())
  name        String
  mode        String   @default("quran")
  content     String   // JSON string of the project state
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExportJob {
  id          String   @id @default(cuid())
  status      String   @default("pending")  // pending, processing, completed, failed
  mode        String   @default("quran")    // quran or hadith
  config      String   // JSON string of the project configuration
  outputUrl   String?  // URL to the exported video file (when completed)
  progress    Int      @default(0)          // 0-100
  error       String?  // Error message (if failed)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
